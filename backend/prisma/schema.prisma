//////////////////////////////////////////////////////
// ADS
//////////////////////////////////////////////////////

model Ad {
  id       String  @id @default(uuid())
  title    String
  text     String
  imageUrl String
  imageName String
  link     String
  buttonText String
  amountPaid Float
  priority Int
  homeAds    HomeAd[]

  isActive Boolean @default(true)
  expireAt DateTime
  @@index([isActive, expireAt])
  createdAt DateTime @default(now())
}



//////////////////////////////////////////////////////
// AUDIT LOG (ADMIN ACTIONS)
//////////////////////////////////////////////////////

model AuditLog {
  id      String @id @default(uuid())
  adminId String
  admin   User   @relation(fields: [adminId], references: [id])

  action     String
  entityType String
  entityId   String

  createdAt DateTime @default(now())

  @@index([adminId])
}
