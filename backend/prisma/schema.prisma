generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//////////////////////////////////////////////////////
// ENUMS
//////////////////////////////////////////////////////

enum UserRole {
  ADMIN
  USER
}

enum ContentStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ReportStatus {
  PENDING
  RESOLVED
  REJECTED
}

enum ReportTargetType {
  COMMENT
  REPLY
  ANSWER
  ANSWER_REPLY
}

enum NotificationType {
  ANSWER_REPLY
  COMMENT_REPLY
  ANSWER_REPLY_REPLY
  COMMENT_REPLY_REPLY
  ADMIN
  CONTACT
  COMMENT
  LIKE
  ANSWER
  REPORT
}

enum ContactRequestStatus {
  PENDING
  ACCEPTED
  DECLINED
}

enum HomeScope {
  ADMIN
  COMMUNITY
}

enum AdPosition {
  TOP
  MIDDLE
  BOTTOM
}

//////////////////////////////////////////////////////
// MODELS
//////////////////////////////////////////////////////

model User {
  id       String   @id @default(uuid())
  googleId String   @unique
  name     String
  email    String   @unique
  avatar   String?
  role     UserRole @default(USER)

  tierId Int?
  tier   Tier? @relation(fields: [tierId], references: [id])

  posts       Post[]
  comments    Comment[]
  replies     Reply[]
  postLikes   PostLike[]
  commentLikes CommentLike[]
  replyLikes   ReplyLike[]
  questions   Question[]
  answers     Answer[]
  answerReplies AnswerReply[]
  questionLikes QuestionLike[]
  answerVotes AnswerVote[]
  answerReplyLikes AnswerReplyLike[]

  sentContactRequests     ContactRequest[] @relation("SentRequests")
  receivedContactRequests ContactRequest[] @relation("ReceivedRequests")

  notifications   Notification[] @relation("Recipient")
  notificationActor Notification[] @relation
  reports         Report[]       @relation("UserReports")
  reviewedReports Report[]       @relation("AdminReviewedReports")

  auditLogs AuditLog[]

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  refreshToken RefreshToken[]

  @@index([role])
  @@index([tierId])
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

//////////////////////////////////////////////////////

model Tier {
  id          Int     @id @default(autoincrement())
  name        String  @unique
  badgeColor  String
  description String?

  users User[]

  createdAt DateTime @default(now())
}

//////////////////////////////////////////////////////
// POSTS SECTION
//////////////////////////////////////////////////////

model Post {
  id       String @id @default(uuid())
  authorId String
  author   User   @relation(fields: [authorId], references: [id])

  title     String
  titleNormalized String
  content   String

  status          ContentStatus @default(PENDING)
  rejectionReason String?

  images   PostImage[]
  comments Comment[]
  tags     PostTag[]
  likes    PostLike[]
  homePosts HomePost[]
  commentReplyNotifications CommentReplyNotification[]
  commentReplyReplyNotifications CommentReplyReplyNotification[]
  
  likesCount Int @default(0)
  commentsCount Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, createdAt, id])
  @@index([status, commentsCount, id])
  @@index([authorId, createdAt, id])
  @@index([titleNormalized])
}

model PostTag {
  id String @id @default(uuid())

  postId String
  tagId String

  name String

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag Tag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@index([tagId, postId])
}

model Tag {
  id String @id @default(uuid())

  normalizedName String @unique

  posts PostTag[]
  questions QuestionTag[]
}

model PostImage {
  id     String @id @default(uuid())
  postId String
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)

  originalName String
  imageUrl String @unique
  publicId String @unique
  width    Int
  height   Int

  createdAt DateTime @default(now())

  @@index([postId, createdAt])
}

model Comment {
  id     String @id @default(uuid())
  postId String
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)

  authorId String
  author   User   @relation(fields: [authorId], references: [id])

  content   String
  likesCount Int @default(0)
  repliesCount Int @default(0)
  
  replies Reply[]
  likes CommentLike[]
  reports Report[]
  commentReplyNotifications CommentReplyNotification[]

  createdAt DateTime @default(now())

  @@index([postId, createdAt, id])
  @@index([authorId])
}

model Reply {
  id        String @id @default(uuid())
  commentId String
  comment   Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  authorId String
  author   User   @relation(fields: [authorId], references: [id])
  parentReplyId String?
  parentReply   Reply? @relation("ReplyThread", fields: [parentReplyId], references: [id])

  content   String
  likesCount Int @default(0)
  depth Int @default(0)
  path String

  replies       Reply[] @relation("ReplyThread")
  commentReplyNotifications CommentReplyNotification[]
  parentReplyReplyNotifications CommentReplyReplyNotification[] @relation("parentCommentReplyReply")
  commentReplyReplyNotifications CommentReplyReplyNotification[]
  likes ReplyLike[]
  reports Report[]

  createdAt DateTime @default(now())

  @@index([commentId])
  @@index([parentReplyId])
  @@index([authorId])

  @@index([commentId, path])
  @@index([path])

  @@index([commentId, createdAt, id])
  @@index([parentReplyId, createdAt, id])

  @@unique([commentId, path])
}

model PostLike {
  userId String
  postId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@id([userId, postId])

  @@index([postId])
}

model CommentLike {
  userId    String
  commentId String

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@id([userId, commentId])

  @@index([commentId])
}

model ReplyLike {
  userId String
  replyId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  reply Reply @relation(fields: [replyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@id([userId, replyId])
  @@index([replyId])
}

//////////////////////////////////////////////////////
// HOME SECTION
//////////////////////////////////////////////////////

model HomePost {
  id String @id @default(uuid())

  postId String
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  scope HomeScope

  position Int

  @@unique([scope, position])
  @@unique([scope, postId])
}

model HomeQuestion {
  id String @id @default(uuid())

  questionId String
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  position Int

  @@unique([position])
  @@unique([questionId])
}

model HomeAd {
  id String @id @default(uuid())

  adId String
  position AdPosition

  @@unique([position])
  ad Ad @relation(fields: [adId], references: [id], onDelete: Cascade)
  @@index([adId])
}

//////////////////////////////////////////////////////
// Q&A SECTION
//////////////////////////////////////////////////////

model Question {
  id       String @id @default(uuid())
  authorId String
  author   User   @relation(fields: [authorId], references: [id])

  title     String
  titleNormalized String
  content   String

  status          ContentStatus @default(PENDING)
  rejectionReason String?

  tags     QuestionTag[]
  answers Answer[]
  likes QuestionLike[]
  homeQuestions HomeQuestion[]
  answerReplyNotifications AnswerReplyNotification[]
  answerReplyReplyNotifications AnswerReplyReplyNotification[]

  likesCount Int @default(0)
  answersCount Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, createdAt, id])
  @@index([status, answersCount, id])
  @@index([authorId, createdAt, id])
  @@index([titleNormalized])
}

model QuestionTag {
  id String @id @default(uuid())

  questionId String
  tagId String

  name String

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  tag Tag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@index([tagId, questionId])
}

model Answer {
  id         String   @id @default(uuid())
  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  authorId String
  author   User   @relation(fields: [authorId], references: [id])

  content   String
  totalVoteValue Int @default(0)
  repliesCount Int @default(0)

  votes   AnswerVote[]
  answerReplies AnswerReply[]
  reports Report[]
  answerReplyNotifications AnswerReplyNotification[]

  createdAt DateTime @default(now())

  @@index([questionId, totalVoteValue, id])
  @@index([authorId])
}

model AnswerReply {
  id        String @id @default(uuid())
  answerId String
  answer   Answer @relation(fields: [answerId], references: [id], onDelete: Cascade)
  authorId String
  author   User   @relation(fields: [authorId], references: [id])
  parentReplyId String?
  parentReply   AnswerReply? @relation("AnswerReplyThread", fields: [parentReplyId], references: [id])

  content   String
  likesCount Int @default(0)
  depth Int @default(0)
  path String

  answerReplies       AnswerReply[] @relation("AnswerReplyThread")
  likes AnswerReplyLike[]
  reports Report[]
  answerReplyNotifications AnswerReplyNotification[]
  parentReplyReplyNotifications AnswerReplyReplyNotification[] @relation("parentAnswerReplyReply")
  answerReplyReplyNotifications AnswerReplyReplyNotification[]

  createdAt DateTime @default(now())

  @@index([answerId])
  @@index([parentReplyId])
  @@index([authorId])

  @@index([answerId, path])
  @@index([path])

  @@index([answerId, createdAt, id])
  @@index([parentReplyId, createdAt, id])

  @@unique([answerId, path])
}

model QuestionLike {
  userId String
  questionId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@id([userId, questionId])

  @@index([questionId])
}

model AnswerVote {
  userId   String
  answerId String
  value Int

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  answer Answer @relation(fields: [answerId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@id([userId, answerId])

  @@index([answerId])
}

model AnswerReplyLike {
  userId String
  answerReplyId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  answerReply AnswerReply @relation(fields: [answerReplyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@id([userId, answerReplyId])
  @@index([answerReplyId])
}

//////////////////////////////////////////////////////
// REPORT SYSTEM
//////////////////////////////////////////////////////

model Report {
  id String @id @default(uuid())

  reporterId String
  reporter   User   @relation("UserReports", fields: [reporterId], references: [id])

  targetType ReportTargetType
  targetId   String

  reason String

  status ReportStatus @default(PENDING)

  reviewedById String?
  reviewedBy   User?   @relation("AdminReviewedReports", fields: [reviewedById], references: [id])

  postId     String?
  commentId  String?
  questionId String?
  answerId   String?
  replyId    String?
  answerReplyId String?

  comment  Comment?  @relation(fields: [commentId], references: [id])
  answer   Answer?   @relation(fields: [answerId], references: [id])
  reply    Reply?    @relation(fields: [replyId], references: [id])
  answerReply AnswerReply? @relation(fields: [answerReplyId], references: [id])

  createdAt DateTime @default(now())

  @@index([status])
  @@index([targetType])
}

//////////////////////////////////////////////////////
// CONTACT SYSTEM
//////////////////////////////////////////////////////

model ContactRequest {
  id String @id @default(uuid())

  requesterId String
  requester   User   @relation("SentRequests", fields: [requesterId], references: [id])

  receiverId String
  receiver   User   @relation("ReceivedRequests", fields: [receiverId], references: [id])

  status ContactRequestStatus @default(PENDING)

  sharedEmail     String?
  sharedPhone     String?
  sharedFacebook  String?
  sharedInstagram String?

  createdAt   DateTime  @default(now())
  respondedAt DateTime?

  @@index([receiverId])
  @@index([requesterId])
}

//////////////////////////////////////////////////////
// NOTIFICATIONS
//////////////////////////////////////////////////////

model Notification {
  id          String   @id @default(uuid())

  type        NotificationType

  recipientId String
  recipient   User @relation("Recipient",fields: [recipientId], references: [id], onDelete: Cascade)

  // read state
  isRead      Boolean  @default(false)

  // aggregation key (e.g., "POST_LIKE:postId")
  //groupKey    String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  lastActorId String
  lastActor   User @relation( fields: [lastActorId], references: [id], onDelete: Cascade)

  // aggregation actors (only used for aggregated types)
  //actors      NotificationActor[]

  // subtypes
  //postLike        PostLikeNotification?
  //postComment     PostCommentNotification?
  answerReply   AnswerReplyNotification?
  commentReply  CommentReplyNotification?  
  commentReplyReply CommentReplyReplyNotification?
  answerReplyReply AnswerReplyReplyNotification?
  //contact         ContactNotification?
  //admin           AdminNotification?
  //moderation      ModerationNotification?

  @@index([recipientId, createdAt(sort: Desc)])
  //@@index([recipientId, groupKey])
  @@index([recipientId, isRead])
  @@index([recipientId, createdAt, id])
}

model AnswerReplyNotification {
  id             String       @id @default(uuid())

  notificationId String       @unique
  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  answerId   String
  answer     Answer   @relation(fields: [answerId], references: [id], onDelete: Cascade)

  replyId String
  reply   AnswerReply @relation(fields: [replyId], references: [id], onDelete: Cascade)
}

model CommentReplyNotification {
  id             String       @id @default(uuid())

  notificationId String       @unique
  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  postId         String
  post           Post         @relation(fields: [postId], references: [id], onDelete: Cascade)

  commentId      String
  comment        Comment      @relation(fields: [commentId], references: [id], onDelete: Cascade)

  replyId        String
  reply          Reply        @relation(fields: [replyId], references: [id], onDelete: Cascade)
}

model CommentReplyReplyNotification {
  id             String       @id @default(uuid())

  notificationId String       @unique
  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  postId         String
  post           Post         @relation(fields: [postId], references: [id], onDelete: Cascade)

  parentReplyId  String
  parentReply    Reply        @relation("parentCommentReplyReply", fields: [parentReplyId], references: [id], onDelete: Cascade)

  replyId        String
  reply          Reply        @relation(fields: [replyId], references: [id], onDelete: Cascade)
}

model AnswerReplyReplyNotification {
  id             String       @id @default(uuid())

  notificationId String       @unique
  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  parentReplyId String
  parentReply   AnswerReply @relation("parentAnswerReplyReply", fields: [parentReplyId], references: [id], onDelete: Cascade)

  replyId String
  reply   AnswerReply @relation(fields: [replyId], references: [id], onDelete: Cascade)
}


//////////////////////////////////////////////////////
// ADS
//////////////////////////////////////////////////////

model Ad {
  id       String  @id @default(uuid())
  title    String
  text     String
  imageUrl String
  imageName String
  link     String
  buttonText String
  amountPaid Float
  priority Int
  homeAds    HomeAd[]

  isActive Boolean @default(true)
  expireAt DateTime
  @@index([isActive, expireAt])
  createdAt DateTime @default(now())
}



//////////////////////////////////////////////////////
// AUDIT LOG (ADMIN ACTIONS)
//////////////////////////////////////////////////////

model AuditLog {
  id      String @id @default(uuid())
  adminId String
  admin   User   @relation(fields: [adminId], references: [id])

  action     String
  entityType String
  entityId   String

  createdAt DateTime @default(now())

  @@index([adminId])
}
