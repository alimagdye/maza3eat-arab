generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//////////////////////////////////////////////////////
// ENUMS
//////////////////////////////////////////////////////

enum UserRole {
  ADMIN
  USER
}

enum ContentStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ReportStatus {
  PENDING
  RESOLVED
  REJECTED
}

enum ReportTargetType {
  COMMENT
  REPLY
  ANSWER
  ANSWER_REPLY
  CONTACT_REQUEST
}

enum NotificationType {
  ANSWER_REPLY
  COMMENT_REPLY
  ANSWER_REPLY_REPLY
  COMMENT_REPLY_REPLY
  ADMIN
  COMMENT
  POST_LIKE
  QUESTION_LIKE
  ANSWER
  REPORT
  POST_APPROVAL
  QUESTION_APPROVAL
}

enum ContactRequestStatus {
  PENDING
  ACCEPTED
  DECLINED
}

enum HomeScope {
  ADMIN
  COMMUNITY
}

enum AdPosition {
  TOP
  MIDDLE
  BOTTOM
}

enum ContactMethodType {
  EMAIL
  WHATSAPP
  FACEBOOK
  INSTAGRAM
}

//////////////////////////////////////////////////////
// MODELS
//////////////////////////////////////////////////////

model User {
  id       String   @id @default(uuid())
  googleId String   @unique
  name     String
  email    String   @unique
  avatar   String
  role     UserRole @default(USER)

  tierId Int? // see it when work on admin upgrade users tiers
  tier   Tier? @relation(fields: [tierId], references: [id])

  posts       Post[]
  comments    Comment[]
  replies     Reply[]
  postLikes   PostLike[]
  commentLikes CommentLike[]
  replyLikes   ReplyLike[]
  questions   Question[]
  answers     Answer[]
  answerReplies AnswerReply[]
  questionLikes QuestionLike[]
  answerVotes AnswerVote[]
  answerReplyLikes AnswerReplyLike[]

  sentContactRequests     ContactRequest[] @relation("SentRequests")
  receivedContactRequests ContactRequest[] @relation("ReceivedRequests")

  notifications   Notification[] @relation("Recipient")
  lastNotificationActor Notification[] @relation("lastActor")
  notificationActors NotificationActor[]
  reports         Report[]       @relation("UserReports")
  reviewedReports Report[]       @relation("AdminReviewedReports")

  auditLogs AuditLog[]

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  refreshToken RefreshToken[]

  @@index([role])
  @@index([tierId])
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

//////////////////////////////////////////////////////

model Tier {
  id          Int     @id @default(autoincrement())
  name        String  @unique
  badgeColor  String
  description String?

  users User[]

  createdAt DateTime @default(now())
}

//////////////////////////////////////////////////////
// POSTS SECTION
//////////////////////////////////////////////////////

model Post {
  id       String @id @default(uuid())
  authorId String
  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  title     String
  titleNormalized String
  content   String

  status          ContentStatus @default(PENDING)
  rejectionReason String?

  images   PostImage[]
  comments Comment[]
  tags     PostTag[]
  likes    PostLike[]
  homePosts HomePost[]
  commentReplyNotifications CommentReplyNotification[]
  commentReplyReplyNotifications CommentReplyReplyNotification[]
  postCommentNotifications PostCommentNotification[]
  postLikeNotifications PostLikeNotification[]
  
  likesCount Int @default(0)
  commentsCount Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, createdAt(sort: Desc), id])
  @@index([status, commentsCount(sort: Desc), id])
  @@index([authorId, createdAt(sort: Desc), id])
  @@index([titleNormalized])
}

model PostTag {
  id String @id @default(uuid())

  postId String
  tagId String

  name String

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag Tag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@index([tagId, postId])
}

model Tag {
  id String @id @default(uuid())

  normalizedName String @unique

  posts PostTag[]
  questions QuestionTag[]
}

model PostImage {
  id     String @id @default(uuid())
  postId String
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)

  originalName String
  imageUrl String @unique
  publicId String @unique
  width    Int
  height   Int

  createdAt DateTime @default(now())

  @@index([postId, createdAt])
}

model Comment {
  id     String @id @default(uuid())
  postId String
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)

  authorId String
  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  content   String
  likesCount Int @default(0)
  repliesCount Int @default(0)
  
  replies Reply[]
  likes CommentLike[]
  reports Report[]
  commentReplyNotifications CommentReplyNotification[]
  postCommentNotifications PostCommentNotification[]

  createdAt DateTime @default(now())

  @@index([postId, createdAt(sort: Desc), id])
  @@index([authorId])
}

model Reply {
  id        String @id @default(uuid())
  commentId String
  comment   Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  authorId String
  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parentReplyId String?
  parentReply   Reply? @relation("ReplyThread", fields: [parentReplyId], references: [id])

  content   String
  likesCount Int @default(0)
  depth Int @default(0)
  path String

  replies       Reply[] @relation("ReplyThread")
  commentReplyNotifications CommentReplyNotification[]
  parentReplyReplyNotifications CommentReplyReplyNotification[] @relation("parentCommentReplyReply")
  commentReplyReplyNotifications CommentReplyReplyNotification[]
  likes ReplyLike[]
  reports Report[]

  createdAt DateTime @default(now())

  @@index([commentId])
  @@index([parentReplyId])
  @@index([authorId])

  @@index([commentId, path])
  @@index([path])

  @@index([commentId, createdAt, id])
  @@index([parentReplyId, createdAt, id])

  @@unique([commentId, path])
}

model PostLike {
  userId String
  postId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@id([userId, postId])

  @@index([postId])
}

model CommentLike {
  userId    String
  commentId String

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@id([userId, commentId])

  @@index([commentId])
}

model ReplyLike {
  userId String
  replyId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  reply Reply @relation(fields: [replyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@id([userId, replyId])
  @@index([replyId])
}

//////////////////////////////////////////////////////
// HOME SECTION
//////////////////////////////////////////////////////

model HomePost {
  id String @id @default(uuid())

  postId String
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  scope HomeScope

  position Int

  @@unique([scope, position])
  @@unique([scope, postId])
}

model HomeQuestion {
  id String @id @default(uuid())

  questionId String
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  position Int

  @@unique([position])
  @@unique([questionId])
}

model HomeAd {
  id String @id @default(uuid())

  adId String
  position AdPosition

  @@unique([position])
  ad Ad @relation(fields: [adId], references: [id], onDelete: Cascade)
  @@index([adId])
}

//////////////////////////////////////////////////////
// Q&A SECTION
//////////////////////////////////////////////////////

model Question {
  id       String @id @default(uuid())
  authorId String
  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  title     String
  titleNormalized String
  content   String

  status          ContentStatus @default(PENDING)
  rejectionReason String?

  tags     QuestionTag[]
  answers Answer[]
  likes QuestionLike[]
  homeQuestions HomeQuestion[]
  answerReplyNotifications AnswerReplyNotification[]
  answerReplyReplyNotifications AnswerReplyReplyNotification[]
  questionAnswerNotifications QuestionAnswerNotification[]
  questionLikeNotifications QuestionLikeNotification[]

  likesCount Int @default(0)
  answersCount Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, createdAt(sort: Desc), id])
  @@index([status, answersCount(sort: Desc), id])
  @@index([authorId, createdAt(sort: Desc), id])
  @@index([titleNormalized])
}

model QuestionTag {
  id String @id @default(uuid())

  questionId String
  tagId String

  name String

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  tag Tag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@index([tagId, questionId])
}

model Answer {
  id         String   @id @default(uuid())
  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  authorId String
  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  content   String
  totalVoteValue Int @default(0)
  repliesCount Int @default(0)

  votes   AnswerVote[]
  answerReplies AnswerReply[]
  reports Report[]
  answerReplyNotifications AnswerReplyNotification[]
  questionAnswerNotifications QuestionAnswerNotification[]

  createdAt DateTime @default(now())

  @@index([questionId, totalVoteValue(sort: Desc), id])
  @@index([authorId])
}

model AnswerReply {
  id        String @id @default(uuid())
  answerId String
  answer   Answer @relation(fields: [answerId], references: [id], onDelete: Cascade)
  authorId String
  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parentReplyId String?
  parentReply   AnswerReply? @relation("AnswerReplyThread", fields: [parentReplyId], references: [id])

  content   String
  likesCount Int @default(0)
  depth Int @default(0)
  path String

  answerReplies       AnswerReply[] @relation("AnswerReplyThread")
  likes AnswerReplyLike[]
  reports Report[]
  answerReplyNotifications AnswerReplyNotification[]
  parentReplyReplyNotifications AnswerReplyReplyNotification[] @relation("parentAnswerReplyReply")
  answerReplyReplyNotifications AnswerReplyReplyNotification[]

  createdAt DateTime @default(now())

  @@index([answerId])
  @@index([parentReplyId])
  @@index([authorId])

  @@index([answerId, path])
  @@index([path])

  @@index([answerId, createdAt, id])
  @@index([parentReplyId, createdAt, id])

  @@unique([answerId, path])
}

model QuestionLike {
  userId String
  questionId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@id([userId, questionId])

  @@index([questionId])
}

model AnswerVote {
  userId   String
  answerId String
  value Int

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  answer Answer @relation(fields: [answerId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@id([userId, answerId])

  @@index([answerId])
}

model AnswerReplyLike {
  userId String
  answerReplyId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  answerReply AnswerReply @relation(fields: [answerReplyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@id([userId, answerReplyId])
  @@index([answerReplyId])
}

//////////////////////////////////////////////////////
// REPORT SYSTEM
//////////////////////////////////////////////////////

model Report {
  id String @id @default(uuid())

  reporterId String
  reporter User @relation("UserReports", fields: [reporterId], references: [id], onDelete: Cascade)

  targetType ReportTargetType
  reason     String

  status ReportStatus @default(PENDING)

  reviewedById String?
  reviewedBy User? @relation("AdminReviewedReports", fields: [reviewedById], references: [id])

  reviewedAt DateTime?

  commentId        String?
  answerId         String?
  replyId          String?
  answerReplyId    String?
  contactRequestId String?

  comment        Comment?        @relation(fields: [commentId], references: [id], onDelete: Cascade)
  answer         Answer?         @relation(fields: [answerId], references: [id], onDelete: Cascade)
  reply          Reply?          @relation(fields: [replyId], references: [id], onDelete: Cascade)
  answerReply    AnswerReply?    @relation(fields: [answerReplyId], references: [id], onDelete: Cascade)
  contactRequest ContactRequest? @relation(fields: [contactRequestId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([status])
  @@index([targetType])

  @@index([commentId])
  @@index([answerId])
  @@index([replyId])
  @@index([answerReplyId])
  @@index([contactRequestId])

  @@unique([reporterId, commentId])
  @@unique([reporterId, answerId])
  @@unique([reporterId, replyId])
  @@unique([reporterId, answerReplyId])
  @@unique([reporterId, contactRequestId])
}

//////////////////////////////////////////////////////
// CONTACT SYSTEM
//////////////////////////////////////////////////////

model ContactRequest {
  id String @id @default(uuid())

  requesterId String
  requester   User   @relation("SentRequests", fields: [requesterId], references: [id], onDelete: Cascade)

  receiverId String
  receiver   User   @relation("ReceivedRequests", fields: [receiverId], references: [id], onDelete: Cascade)

  status ContactRequestStatus @default(PENDING)
  reason String
  receiverHasRead Boolean @default(false)
  requesterHasRead Boolean @default(false)

  contactMethod ContactMethod?

  reports Report[]

  lastActivityAt DateTime @default(now())
  createdAt   DateTime  @default(now())

  @@unique([requesterId, receiverId])
}

model ContactMethod {
  id String @id @default(uuid())

  contactRequestId String @unique
  contactRequest ContactRequest @relation(fields: [contactRequestId], references: [id], onDelete: Cascade)

  type ContactMethodType
  value String

  createdAt DateTime @default(now())
}

//////////////////////////////////////////////////////
// NOTIFICATIONS
//////////////////////////////////////////////////////

model Notification {
  id          String   @id @default(uuid())

  type        NotificationType

  recipientId String
  recipient   User @relation("Recipient",fields: [recipientId], references: [id], onDelete: Cascade)

  // read state
  isRead      Boolean  @default(false)

  // aggregation key (e.g., "POST_LIKE:postId") 
  groupKey String? 

  createdAt DateTime @default(now()) 
  lastActivityAt DateTime @default(now()) // used for sorting 

  lastActorId String 
  lastActor User @relation("lastActor", fields: [lastActorId], references: [id], onDelete: Cascade) 

  numberOfActors Int @default(1) // for aggregated notifications, counts how many actors are involved 
  actors NotificationActor[] // relation to track all actors involved in this notification

  // subtypes
  postLike        PostLikeNotification?
  questionLike     QuestionLikeNotification?
  postComment PostCommentNotification?
  questionAnswer QuestionAnswerNotification?
  commentReply  CommentReplyNotification?  
  answerReply   AnswerReplyNotification?
  commentReplyReply CommentReplyReplyNotification?
  answerReplyReply AnswerReplyReplyNotification?
  //contact         ContactNotification?
  //admin           AdminNotification?
  //moderation      ModerationNotification?

  @@index([recipientId, lastActivityAt(sort: Desc)]) 
  @@index([recipientId, groupKey]) 
  @@index([recipientId, isRead]) 
  @@index([recipientId, lastActivityAt, id])
}

model NotificationActor { 
  id String @id @default(uuid()) 

  notificationId String 
  notification Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  actorId String 
  actor User @relation(fields: [actorId], references: [id], onDelete: Cascade) 
  
  @@unique([notificationId, actorId]) 
}

model AnswerReplyNotification {
  id             String       @id @default(uuid())

  notificationId String       @unique
  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  answerId   String
  answer     Answer   @relation(fields: [answerId], references: [id], onDelete: Cascade)

  replyId String
  reply   AnswerReply @relation(fields: [replyId], references: [id], onDelete: Cascade)
}

model CommentReplyNotification {
  id             String       @id @default(uuid())

  notificationId String       @unique
  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  postId         String
  post           Post         @relation(fields: [postId], references: [id], onDelete: Cascade)

  commentId      String
  comment        Comment      @relation(fields: [commentId], references: [id], onDelete: Cascade)

  replyId        String
  reply          Reply        @relation(fields: [replyId], references: [id], onDelete: Cascade)
}

model CommentReplyReplyNotification {
  id             String       @id @default(uuid())

  notificationId String       @unique
  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  postId         String
  post           Post         @relation(fields: [postId], references: [id], onDelete: Cascade)

  parentReplyId  String
  parentReply    Reply        @relation("parentCommentReplyReply", fields: [parentReplyId], references: [id], onDelete: Cascade)

  replyId        String
  reply          Reply        @relation(fields: [replyId], references: [id], onDelete: Cascade)
}

model AnswerReplyReplyNotification {
  id             String       @id @default(uuid())

  notificationId String       @unique
  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  parentReplyId String
  parentReply   AnswerReply @relation("parentAnswerReplyReply", fields: [parentReplyId], references: [id], onDelete: Cascade)

  replyId String
  reply   AnswerReply @relation(fields: [replyId], references: [id], onDelete: Cascade)
}

model PostCommentNotification {
  id String @id @default(uuid())

  notificationId String @unique 
  notification Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  postId String 
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade) // last comment preview 
  
  lastCommentId String?
  lastComment Comment? @relation(fields: [lastCommentId], references: [id], onDelete: SetNull) 
}

model QuestionAnswerNotification {
  id String @id @default(uuid())

  notificationId String @unique 
  notification Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  questionId String 
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade) // last comment preview 
  
  lastAnswerId String?
  lastAnswer Answer? @relation(fields: [lastAnswerId], references: [id], onDelete: SetNull) 
}

model PostLikeNotification {
  id String @id @default(uuid())

  notificationId String @unique 
  notification Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  postId String 
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade) // liked post preview 
}

model QuestionLikeNotification {
  id String @id @default(uuid())

  notificationId String @unique 
  notification Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  questionId String 
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade) // liked question preview 
}

