{
    "name": "maza3eat-arab",
    "version": "1.0.0",
    "description": "A social media traveling blog platform using Node.js/typescript, Express, and MongoDB.",
    "keywords": [
        "social media",
        "traveling",
        "maza3eat"
    ],
    "main": "dist/index.js",
    "type": "module",
    "engines": {
        "node": ">=20"
    },
    "scripts": {
        "test": "echo \"Error: no test specified\" && exit 1",
        "dev": "tsx watch src/index.ts",
        "build": "tsc",
        "start": "node dist/index.js",
        "db:migrate": "prisma migrate dev",
        "db:seed": "prisma db seed",
        "db:setup": "prisma migrate dev && prisma db seed",
        "db:setup:prod": "prisma generate && prisma migrate deploy && prisma db seed"
    },
    "prisma": {
        "seed": "node prisma/seed.js"
    },
    "author": "Ali Magdy",
    "license": "MIT",
    "dependencies": {
        "@prisma/client": "^6.19.2",
        "cloudinary": "^2.9.0",
        "compression": "^1.8.1",
        "cookie-parser": "^1.4.7",
        "cors": "^2.8.6",
        "dotenv": "^17.2.0",
        "express": "^5.1.0",
        "express-rate-limit": "^8.3.2",
        "express-validator": "^7.2.1",
        "googleapis": "^171.4.0",
        "helmet": "^8.1.0",
        "jsonwebtoken": "^9.0.2",
        "morgan": "^1.10.1",
        "multer": "^2.1.1",
        "multer-storage-cloudinary": "^2.2.1",
        "sanitize-html": "^2.17.0"
    },
    "devDependencies": {
        "@types/compression": "^1.8.1",
        "@types/cookie-parser": "^1.4.10",
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.3",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/morgan": "^1.9.10",
        "@types/multer": "^2.1.0",
        "@types/node": "^24.12.2",
        "@types/sanitize-html": "^2.16.0",
        "prisma": "^6.19.2",
        "ts-node": "^10.9.2",
        "tsx": "^4.21.0",
        "typescript": "^5.8.3"
    }
}
