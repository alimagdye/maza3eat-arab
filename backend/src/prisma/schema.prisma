generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//////////////////////////////////////////////////////
// ENUMS
//////////////////////////////////////////////////////

enum UserRole {
  ADMIN
  USER
}

enum ContentStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ReportStatus {
  PENDING
  RESOLVED
  REJECTED
}

enum ReportTargetType {
  COMMENT
  REPLY
  ANSWER
  ANSWER_REPLY
}

enum NotificationType {
  ADMIN
  CONTACT
  COMMENT
  LIKE
  ANSWER
  REPORT
}

enum ContactRequestStatus {
  PENDING
  ACCEPTED
  DECLINED
}

//////////////////////////////////////////////////////
// MODELS
//////////////////////////////////////////////////////

model User {
  id       String   @id @default(uuid())
  googleId String   @unique
  name     String
  email    String   @unique
  avatar   String?
  role     UserRole @default(USER)

  tierId Int?
  tier   Tier? @relation(fields: [tierId], references: [id])

  posts       Post[]
  comments    Comment[]
  replies     Reply[]
  postLikes   PostLike[]
  commentLikes CommentLike[]
  replyLikes   ReplyLike[]
  questions   Question[]
  answers     Answer[]
  answerReplies AnswerReply[]
  answerVotes AnswerVote[]

  sentContactRequests     ContactRequest[] @relation("SentRequests")
  receivedContactRequests ContactRequest[] @relation("ReceivedRequests")

  notifications   Notification[]
  reports         Report[]       @relation("UserReports")
  reviewedReports Report[]       @relation("AdminReviewedReports")

  auditLogs AuditLog[]

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  refreshToken RefreshToken[]

  @@index([role])
  @@index([tierId])
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

//////////////////////////////////////////////////////

model Tier {
  id          Int     @id @default(autoincrement())
  name        String  @unique
  badgeColor  String
  description String?

  users User[]

  createdAt DateTime @default(now())
}

//////////////////////////////////////////////////////
// POSTS SECTION
//////////////////////////////////////////////////////

model Post {
  id       String @id @default(uuid())
  authorId String
  author   User   @relation(fields: [authorId], references: [id])

  title     String
  titleNormalized String
  content   String

  status          ContentStatus @default(PENDING)
  rejectionReason String?

  images   PostImage[]
  comments Comment[]
  tags     PostTag[]
  likes    PostLike[]
  likesCount Int @default(0)
  commentsCount Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([authorId])
  @@index([titleNormalized])
  @@index([createdAt])
  @@index([commentsCount])
  @@index([likesCount])
}

model PostTag {
  postId String
  name   String
  normalizedName String

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@id([postId, normalizedName])
  @@index([normalizedName])
}

model PostImage {
  id     String @id @default(uuid())
  postId String
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)

  originalName String
  imageUrl String @unique
  publicId String @unique
  width    Int
  height   Int

  createdAt DateTime @default(now())

  @@index([postId])
}

model Comment {
  id     String @id @default(uuid())
  postId String
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)

  authorId String
  author   User   @relation(fields: [authorId], references: [id])

  content   String
  likesCount Int @default(0)
  
  replies Reply[]
  likes CommentLike[]
  reports Report[]

  createdAt DateTime @default(now())

  @@index([postId])
  @@index([createdAt])
  @@index([authorId])
}

model Reply {
  id        String @id @default(uuid())
  commentId String
  comment   Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  authorId String
  author   User   @relation(fields: [authorId], references: [id])
  parentReplyId String?
  parentReply   Reply? @relation("ReplyThread", fields: [parentReplyId], references: [id])

  content   String
  likesCount Int @default(0)
  depth Int @default(0)
  path String

  replies       Reply[] @relation("ReplyThread")
  likes ReplyLike[]
  reports Report[]

  createdAt DateTime @default(now())

  @@index([commentId])
  @@index([parentReplyId])
  @@index([authorId])
}

model PostLike {
  userId String
  postId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@id([userId, postId])
}

model CommentLike {
  userId    String
  commentId String

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@id([userId, commentId])
}

model ReplyLike {
  userId String
  replyId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  reply Reply @relation(fields: [replyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@id([userId, replyId])
}

//////////////////////////////////////////////////////
// Q&A SECTION
//////////////////////////////////////////////////////

model Question {
  id       String @id @default(uuid())
  authorId String
  author   User   @relation(fields: [authorId], references: [id])

  title     String
  titleNormalized String
  content   String

  status          ContentStatus @default(PENDING)
  rejectionReason String?
  isDeleted       Boolean       @default(false)

  answers Answer[]

  createdAt DateTime @default(now())

  @@index([status])
  @@index([authorId])
}

model Answer {
  id         String   @id @default(uuid())
  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  authorId String
  author   User   @relation(fields: [authorId], references: [id])

  content   String
  isDeleted Boolean @default(false)

  votes   AnswerVote[]
  answerReplies AnswerReply[]
  reports Report[]

  createdAt DateTime @default(now())

  @@index([questionId])
  @@index([authorId])
}

model AnswerReply {
  id        String @id @default(uuid())
  answerId String
  answer   Answer @relation(fields: [answerId], references: [id], onDelete: Cascade)
  authorId String
  author   User   @relation(fields: [authorId], references: [id])
  parentReplyId String?
  parentReply   AnswerReply? @relation("AnswerReplyThread", fields: [parentReplyId], references: [id])

  content   String
  depth Int @default(0)
  path String

  answerReplies       AnswerReply[] @relation("AnswerReplyThread")
  reports Report[]

  createdAt DateTime @default(now())

  @@index([answerId])
  @@index([parentReplyId])
  @@index([authorId])
}

model AnswerVote {
  userId   String
  answerId String
  value    Int // 1 or -1

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  answer Answer @relation(fields: [answerId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@id([userId, answerId])
}

//////////////////////////////////////////////////////
// REPORT SYSTEM
//////////////////////////////////////////////////////

model Report {
  id String @id @default(uuid())

  reporterId String
  reporter   User   @relation("UserReports", fields: [reporterId], references: [id])

  targetType ReportTargetType
  targetId   String

  reason String

  status ReportStatus @default(PENDING)

  reviewedById String?
  reviewedBy   User?   @relation("AdminReviewedReports", fields: [reviewedById], references: [id])

  postId     String?
  commentId  String?
  questionId String?
  answerId   String?
  replyId    String?
  answerReplyId String?

  comment  Comment?  @relation(fields: [commentId], references: [id])
  answer   Answer?   @relation(fields: [answerId], references: [id])
  reply    Reply?    @relation(fields: [replyId], references: [id])
  answerReply AnswerReply? @relation(fields: [answerReplyId], references: [id])

  createdAt DateTime @default(now())

  @@index([status])
  @@index([targetType])
}

//////////////////////////////////////////////////////
// CONTACT SYSTEM
//////////////////////////////////////////////////////

model ContactRequest {
  id String @id @default(uuid())

  requesterId String
  requester   User   @relation("SentRequests", fields: [requesterId], references: [id])

  receiverId String
  receiver   User   @relation("ReceivedRequests", fields: [receiverId], references: [id])

  status ContactRequestStatus @default(PENDING)

  sharedEmail     String?
  sharedPhone     String?
  sharedFacebook  String?
  sharedInstagram String?

  createdAt   DateTime  @default(now())
  respondedAt DateTime?

  @@index([receiverId])
  @@index([requesterId])
}

//////////////////////////////////////////////////////
// NOTIFICATIONS
//////////////////////////////////////////////////////

model Notification {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type    NotificationType
  title   String
  message String
  isRead  Boolean          @default(false)

  relatedEntityType String?
  relatedEntityId   String?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([type])
}

//////////////////////////////////////////////////////
// ADS
//////////////////////////////////////////////////////

model Ad {
  id       String  @id @default(uuid())
  title    String
  imageUrl String
  link     String
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
}



//////////////////////////////////////////////////////
// AUDIT LOG (ADMIN ACTIONS)
//////////////////////////////////////////////////////

model AuditLog {
  id      String @id @default(uuid())
  adminId String
  admin   User   @relation(fields: [adminId], references: [id])

  action     String
  entityType String
  entityId   String

  createdAt DateTime @default(now())

  @@index([adminId])
}
